{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/api/feed/rss",
      "destination": "/feed.xml",
      "permanent": true
    },
    {
      "source": "/rss",
      "destination": "/feed.xml",
      "permanent": true
    },
    {
      "source": "/feed",
      "destination": "/playground/feed",
      "permanent": true
    },
    {
      "source": "/hawaii",
      "destination": "/logbook/big-island-hawaii",
      "permanent": true
    },
    {
      "source": "/opensession/install",
      "destination": "https://raw.githubusercontent.com/josiahwiebe/opensession/main/scripts/install.sh",
      "permanent": false
    }
  ]
}
